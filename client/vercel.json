{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/api/(.*)",
      "dest": "https://travelzoltan-gb.onrender.com/api/$1"
    },
    {
      "src": "^(?!.*\\.(js|css|png|jpg|jpeg|svg|ico|json)$).*",
      "dest": "/index.html"
    }
  ]
}